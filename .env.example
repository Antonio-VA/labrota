# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Anthropic (Vercel AI SDK)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# HMAC signing secrets — each must be a random 32+ char string, kept separate from DB keys
# Generate with: openssl rand -hex 32
LEAVE_TOKEN_SECRET=
SWAP_TOKEN_SECRET=
OUTLOOK_STATE_SECRET=

# Cron endpoint secret — must match the value set in Vercel Cron job configuration
CRON_SECRET=

# Microsoft Outlook Calendar Sync (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://www.labrota.app/api/outlook-callback
OUTLOOK_TOKEN_ENCRYPTION_KEY=
